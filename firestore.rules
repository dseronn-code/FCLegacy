rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /careers/{careerId} {
      // Anyone can read if the career is marked public
      // Otherwise, only the creator (userId matches authenticated uid) can read
      allow read: if resource == null 
                  || resource.data.isPublic == true 
                  || (request.auth != null && request.auth.uid == resource.data.userId);

      // Only the authenticated owner can create, update, or delete
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
