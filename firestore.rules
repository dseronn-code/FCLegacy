rules_version = '2';
 
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /careers/{careerId} {
      // Anyone can read if the career is marked public
      // Otherwise, only the creator or admin can read
      allow read: if resource == null 
                  || resource.data.isPublic == true 
                  || (request.auth != null && (request.auth.uid == resource.data.userId || isAdmin()));
 
      // Authenticated owner can create, update, or delete; admin can delete or edit as well
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && (request.auth.uid == resource.data.userId && request.auth.uid == request.resource.data.userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }
 
    match /users/{userId} {
      // Any authenticated user can read user profiles, but only the owner or an admin can modify theirs
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /subscriptions/{subId} {
      // Only the subscriber or an admin can view subscription records
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin(); // Subscriptions are normally generated server-side / by admin
    }

    match /system_config/{configId} {
      // Anyone (authenticated or guest) can read system configs (e.g. prices, global announcements)
      allow read: if true;
      allow write: if isAdmin(); // Only admins can update global prices, limits and banners
    }

    match /reactivations/{tokenId} {
      // Allow read for authenticated owners of the token, or admins
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      // Only admins (the backend server) can write (create/update) reactivation tokens
      allow write: if isAdmin();
    }
  }
}
